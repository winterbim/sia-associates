# Resend API key for contact form emails
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email where contact form submissions are sent
CONTACT_EMAIL=contact@sia-associates.fr

# From email (must be verified domain in Resend)
FROM_EMAIL=no-reply@sia-associates.fr

# Groq API key for AI blog article generation
GROQ_API_KEY=gsk_xxxxxxxxxxxx

# Optional: token to protect the blog generation endpoint
BLOG_GENERATE_TOKEN=
